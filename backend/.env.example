# ─── Provider Selection ───────────────────────────────────────────────
# Options: "gemini" (default), "openai"
LLM_PROVIDER=gemini

# ─── Gemini Settings ──────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── OpenAI Settings ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
